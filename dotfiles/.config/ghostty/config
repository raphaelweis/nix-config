adjust-cursor-thickness = 1
background-opacity = 1
confirm-close-surface = true
cursor-invert-fg-bg = true
cursor-style = block
cursor-style-blink = false
font-family = monospace
font-size = 10
gtk-single-instance = true
gtk-titlebar = false
keybind = ctrl+enter=unbind
keybind = performable:alt+c=copy_to_clipboard
keybind = performable:alt+v=paste_from_clipboard
shell-integration-features = no-cursor
theme = Gruvbox Dark Hard
window-padding-x = 5
window-padding-y = 5
font-feature = -calt

keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right
keybind = ctrl+cmd+h=goto_split:left
keybind = ctrl+cmd+j=goto_split:down
keybind = ctrl+cmd+k=goto_split:up
keybind = ctrl+cmd+l=goto_split:right

